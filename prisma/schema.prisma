// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Use SQLite for zero-setup (file:./dev.db) or PostgreSQL for production
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  createdAt     DateTime @default(now())

  accounts      Account[]
  sessions      Session[]
  tweets        TimecodedTweet[]
  likes         TweetLike[]
  comments      TweetComment[]
  watchSessions WatchSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

model Title {
  id             String   @id @default(cuid())
  tmdbId         String
  type          String   // "movie" | "episode"
  title         String
  runtimeSeconds Int
  metadata      Json?    // poster path, overview, etc.
  createdAt     DateTime @default(now())

  tweets        TimecodedTweet[]
  watchSessions WatchSession[]

  @@unique([type, tmdbId])
}

model TimecodedTweet {
  id              String   @id @default(cuid())
  userId          String
  titleId         String
  timecodeSeconds Int
  content         String
  createdAt       DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    Title         @relation(fields: [titleId], references: [id], onDelete: Cascade)
  likes    TweetLike[]
  comments TweetComment[]
}

model TweetLike {
  id        String   @id @default(cuid())
  userId    String
  tweetId   String
  createdAt DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet TimecodedTweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([userId, tweetId])
}

model TweetComment {
  id        String   @id @default(cuid())
  userId    String
  tweetId   String
  content   String
  createdAt DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweet TimecodedTweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)
}

model WatchSession {
  id                 String   @id @default(cuid())
  userId             String
  titleId            String
  lastPositionSeconds Int     @default(0)
  lastActiveAt       DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)
}
