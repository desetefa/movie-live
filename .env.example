# === Quick Start (no API keys) ===
# Use SQLite and mock data - no TMDB or GitHub needed
DATABASE_URL="file:./dev.db"
USE_MOCK_DATA="true"

# Optional: generate a secret for NextAuth
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# === Production (with real APIs) ===
# Uncomment and set when ready:
# DATABASE_URL="postgresql://user:password@localhost:5432/movie_live"
# TMDB_API_KEY="your-tmdb-api-key"
# GITHUB_ID="your-github-oauth-client-id"
# GITHUB_SECRET="your-github-oauth-client-secret"
